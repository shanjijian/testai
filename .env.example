# .env.example - TestAI Configuration Template
# =================================================================
# Copy this file to .env and fill in your actual credentials.

# --- LLMSettings ---
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4-turbo

# --- JDCloudSettings ---
JDCLOUD_AK=your_jdcloud_access_key
JDCLOUD_SK=your_jdcloud_secret_key
DEFAULT_REGION=cn-north-1

# --- StorageSettings (COS) ---
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_REGION=ap-beijing
COS_BUCKET=your_bucket_name

# --- LangfuseSettings ---
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- SandboxSettings ---
OPENSANDBOX_API_KEY=your_sandbox_api_key
OPENSANDBOX_URL=http://127.0.0.1:8090

# --- DatabaseSettings ---
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5433/testai_agent

# --- Others ---
TAVILY_API_KEY=your_tavily_api_key
